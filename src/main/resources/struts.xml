<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <constant name="struts.devMode" value="true" />
    <constant name="struts.ui.theme" value="simple" />

    <package name="auth-default" extends="json-default">
        <interceptors>
            <interceptor name="auth" class="com.demo.interceptor.AuthenticationInterceptor"/>
            <interceptor name="audit" class="com.demo.interceptor.AuditInterceptor"/>
            <interceptor-stack name="authStack">
                <interceptor-ref name="audit"/>
                <interceptor-ref name="auth"/>
                <interceptor-ref name="defaultStack"/>
            </interceptor-stack>
        </interceptors>

        <default-interceptor-ref name="authStack"/>

        <global-results>
            <result name="login" type="redirect">login.jsp</result>
        </global-results>
    </package>
</struts>
